<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>Billing Calculator</title>
    <style>
        /* Centers everything perfectly in the browser viewport with an image background */
        body {
            display: flex;
            flex-direction: column;
            align-items: center;
            justify-content: center;
            min-height: 100vh;
            margin: 0;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            
            /* Added background image logic here */
            background-image: url('pic.jpg'); /* Change extension to .png or .jpeg if needed */
            background-size: cover;           /* Ensures the image fills the entire screen */
            background-position: center;      /* Centers the background image */
            background-repeat: no-repeat;     /* Prevents the image from repeating */
            background-attachment: fixed;     /* Keeps the background fixed while scrolling */
            
            color: #333333;
        }

        /* Creative Form Container Card with slightly adjusted opacity to see the background */
        .calculator-box {
            background: rgba(255, 255, 255, 0.95); /* Semi-transparent white card */
            padding: 35px 40px;
            border-radius: 16px;
            box-shadow: 0 10px 30px rgba(0, 0, 0, 0.2);
            width: 100%;
            max-width: 360px;
            box-sizing: border-box;
            transition: transform 0.2s;
            backdrop-filter: blur(5px); /* Smooth blur effect behind the card */
        }

        .calculator-box:hover {
            transform: translateY(-2px);
        }

        /* Clean Header Typography */
        h1 {
            margin-top: 0;
            margin-bottom: 25px;
            font-size: 1.8rem;
            color: #2c3e50;
            font-weight: 700;
            text-align: center;
            letter-spacing: -0.5px;
        }

        /* Form Group Components */
        .form-group {
            margin-bottom: 18px;
            text-align: left;
        }

        label {
            display: block;
            font-size: 0.85rem;
            font-weight: 600;
            color: #5a6a85;
            margin-bottom: 6px;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        input {
            width: 100%;
            padding: 10px 14px;
            border: 2px solid #e2e8f0;
            border-radius: 8px;
            font-size: 0.95rem;
            box-sizing: border-box;
            transition: all 0.2s ease-in-out;
            color: #2d3748;
            background-color: #f8fafc;
        }

        input:focus {
            outline: none;
            border-color: #4f46e5;
            background-color: #ffffff;
            box-shadow: 0 0 0 3px rgba(79, 70, 229, 0.1);
        }

        /* Creative Action Button */
        button {
            width: 100%;
            padding: 12px;
            background: linear-gradient(135deg, #4f46e5 0%, #3730a3 100%);
            color: #ffffff;
            border: none;
            border-radius: 8px;
            font-size: 1rem;
            font-weight: 600;
            cursor: pointer;
            margin-top: 10px;
            margin-bottom: 20px;
            box-shadow: 0 4px 12px rgba(79, 70, 229, 0.25);
            transition: all 0.2s;
        }

        button:hover {
            background: linear-gradient(135deg, #4338ca 0%, #2e267d 100%);
            box-shadow: 0 6px 16px rgba(79, 70, 229, 0.35);
        }

        button:active {
            transform: scale(0.98);
        }

        /* Stylized Dynamic Results Metrics */
        .results-panel {
            background-color: #f8fafc;
            border-radius: 10px;
            padding: 15px;
            border: 1px dashed #cbd5e1;
        }

        .result-item {
            display: flex;
            justify-content: space-between;
            align-items: center;
            margin-bottom: 8px;
            font-size: 0.95rem;
            color: #475569;
        }

        .result-item.total {
            margin-top: 12px;
            padding-top: 12px;
            border-top: 2px solid #e2e8f0;
            font-size: 1.2rem;
            font-weight: 700;
            color: #1e293b;
        }

        .result-item span:last-child {
            font-family: 'Courier New', Courier, monospace;
            font-weight: 600;
        }

        /* Footnote Student ID Styling with background readability protection */
        h2 {
            color: #1e293b;
            margin-top: 25px;
            font-size: 0.9rem;
            font-weight: 600;
            letter-spacing: 1px;
            background: rgba(255, 255, 255, 0.85);
            padding: 8px 20px;
            border-radius: 20px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
            backdrop-filter: blur(5px);
        }
    </style>
</head>
<body>

    <div class="calculator-box">
        <h1>Billing Calculator</h1>

        <div class="form-group">
            <label for="custName">Customer Name</label>
            <input type="text" id="custName" placeholder="John Doe">
        </div>

        <div class="form-group">
            <label for="prodName">Product Name</label>
            <input type="text" id="prodName" placeholder="Wireless Mouse">
        </div>

        <div class="form-group">
            <label for="price">Price per Item ($)</label>
            <input type="number" id="price" value="0" min="0" step="0.01">
        </div>

        <div class="form-group">
            <label for="quantity">Quantity</label>
            <input type="number" id="quantity" value="1" min="1">
        </div>

        <div class="form-group">
            <label for="tax">Tax (%)</label>
            <input type="number" id="tax" value="0" min="0" step="0.1">
        </div>

        <button onclick="calculateTotal()">Calculate Bill</button>

        <div class="results-panel">
            <div class="result-item">
                <span>Subtotal:</span>
                <span id="subtotal">$0.00</span>
            </div>
            <div class="result-item total">
                <span>Total Amount:</span>
                <span id="total">$0.00</span>
            </div>
        </div>
    </div>

    <script src="script.js"></script>
    
    <h2>PRN: 24070521070</h2>

    <script>
        window.onload = function() {
            greet();
        };

        function greet() {
            alert("Welcome to billing calculator!");

            console.table([
                {
                    Name : "Sample User",
                    Course : "JavaScript"
                }
            ]);
            console.time("Execution");
            console.timeEnd("Execution");
        }

        function calculateTotal() {
            var price = parseFloat(document.getElementById('price').value) || 0;
            var quantity = parseFloat(document.getElementById('quantity').value) || 0;
            var taxRate = parseFloat(document.getElementById('tax').value) || 0;
            
            var subtotal = price * quantity;
            var taxAmount = subtotal * (taxRate / 100);
            var finalTotal = subtotal + taxAmount;
            
            document.getElementById('subtotal').innerText = "$" + subtotal.toFixed(2);
            document.getElementById('total').innerText = "$" + finalTotal.toFixed(2);
        }
    </script>

</body>
</html>
